# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/pitchflow

# ── Auth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Redis (Upstash or local) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Custom AI (OpenAI-compatible) ───────────────────────
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# ── Email ───────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Prospect Discovery ─────────────────────────────────
HUNTER_IO_API_KEY=
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
SERPAPI_KEY=

# ── Alerts (Phase 2) ───────────────────────────────────
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# ── Billing (Phase 2) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── App Config ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PitchFlow
NODE_ENV=development

# ── Cron Security ──────────────────────────────────────
CRON_SECRET=
