# App
NODE_ENV=production
NEXTAUTH_URL=http://YOUR_SERVER_IP:3000
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXT_PUBLIC_APP_NAME=PitchFlow
CRON_SECRET=replace-with-openssl-rand-base64-32

# Database / Redis
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/pitchflow
REDIS_URL=redis://redis:6379

# EmailEngine
EMAILENGINE_URL=http://emailengine:3000
EMAILENGINE_ACCESS_TOKEN=replace-with-emailengine-api-token
EMAILENGINE_PREPARED_TOKEN=replace-with-emailengine-prepared-token
EMAILENGINE_WEBHOOK_BASE_URL=http://YOUR_SERVER_IP:3000
EMAILENGINE_WEBHOOK_SECRET=
EMAILENGINE_INTERNAL_SECRET=replace-with-openssl-rand-base64-32

# Search
SEARXNG_URL=http://searxng:8080
SEARCH_PROVIDERS=searxng
DISCOVERY_RULE_VARIANT=B

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# Discovery
HUNTER_IO_API_KEY=
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
SERPAPI_KEY=

# Tracking
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# Billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
